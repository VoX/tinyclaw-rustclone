{
  "name": "rustclone",
  "version": "0.1.0",
  "description": "2D top-down multiplayer survival game inspired by Rust",
  "type": "module",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "npx esbuild client/index.js --bundle --outfile=client/dist/bundle.js --format=esm --servedir=client/dist --serve=3000",
    "build:client": "npx esbuild client/index.js --bundle --outfile=client/dist/bundle.js --format=esm --minify",
    "start": "node server/index.js"
  },
  "dependencies": {
    "bitecs": "^0.3.40",
    "simplex-noise": "^4.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
